APP_DATA_DIR=data

# LLM provider (OpenAI-compatible endpoint)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
AGENT_VERBOSE=false

# Snowflake connection (used as default when no per-tenant warehouse config exists)
SNOWFLAKE_AUTH_TYPE=password
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=
# SDK logs: OFF, ERROR, WARN, INFO, DEBUG, TRACE
SNOWFLAKE_SDK_LOG_LEVEL=OFF
# Per-tenant warehouse: use Admin UI wizard. For password auth, set passwordEnvVar in wizard (e.g. SNOWFLAKE_PASSWORD or TENANT_X_SNOWFLAKE_PASSWORD).

# Slack bot server (for Events API transport)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_PORT=3000
SLACK_DEFAULT_TENANT_ID=
SLACK_DEFAULT_PROFILE_NAME=default
# Optional JSON map: {"T01234567":"tenant_a","T07654321":"tenant_b"}
SLACK_TEAM_TENANT_MAP=
# Owner org (blueprintdata): comma-separated team/enterprise IDs allowed to use default tenant
SLACK_OWNER_TEAM_IDS=
SLACK_OWNER_ENTERPRISE_IDS=
# When true, non-owner contexts require explicit channel/user/shared-team mapping (Phase 3)
SLACK_STRICT_TENANT_ROUTING=false

# Admin UI (internal use only, no auth)
ADMIN_PORT=3100
