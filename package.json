{
  "name": "agent-blue",
  "version": "1.0.0",
  "description": "Analytics agent platform with Snowflake + dbt support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "slack:server": "npm run dev -- slack --profile default --port 3000",
    "tunnel": "cloudflared tunnel --config cloudflared-agent-blue.yml run agent-blue-slack",
    "slack:local": "concurrently -k -n tunnel,slack -c cyan,green \"npm run tunnel\" \"npm run slack:server\"",
    "admin:ui": "npm run dev -- admin-ui --port 3100"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mporracindie/agent-blue.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mporracindie/agent-blue/issues"
  },
  "homepage": "https://github.com/mporracindie/agent-blue#readme",
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "snowflake-sdk": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
